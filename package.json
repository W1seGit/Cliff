{
  "name": "dashboard",
  "version": "0.1.9",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:lan": "node scripts/dev-lan.mjs",
    "dev:clean": "node scripts/clean-next.mjs && next dev",
    "install:run": "node scripts/install-run.mjs",
    "build": "npm run daemon:package",
    "build:daemon-web": "node scripts/build-daemon-web.mjs",
    "start": "node scripts/start-packaged-daemon.mjs",
    "start:lan": "npm start",
    "serve:lan": "npm run install:run",
    "daemon:build": "node scripts/build-daemon.mjs",
    "daemon:package": "node scripts/package-daemon.mjs",
    "daemon:run": "node scripts/run-daemon.mjs",
    "daemon:status": "node scripts/status-daemon.mjs",
    "daemon:stop": "node scripts/stop-daemon.mjs",
    "daemon:test": "cd daemon && go test ./...",
    "daemon:verify-archive": "node scripts/verify-daemon-archive.mjs",
    "daemon:verify-package": "node scripts/verify-daemon-package.mjs",
    "daemon:verify-release": "node scripts/verify-daemon-release.mjs",
    "verify": "npm run lint && npm run verify:daemon-defaults && npm run daemon:test && npm run smoke:daemon-web && npm run smoke:daemon-package && npm run smoke:install-package && npm run smoke:install-run && npm run smoke:start && npm run smoke:daemon-ui && npm run smoke:daemon && npm run smoke:auth && npm run smoke:ui",
    "verify:online-metadata": "npm run verify:minecraft-meta",
    "smoke:auth": "node scripts/smoke-auth.mjs",
    "smoke:daemon": "node scripts/smoke-daemon.mjs",
    "smoke:daemon-package": "node scripts/smoke-daemon-package.mjs",
    "smoke:daemon-ui": "node scripts/smoke-daemon-ui.mjs",
    "smoke:daemon-web": "node scripts/smoke-daemon-web.mjs",
    "smoke:install-package": "node scripts/smoke-install-package.mjs",
    "smoke:install-run": "node scripts/smoke-install-run.mjs",
    "smoke:start": "node scripts/smoke-start.mjs",
    "smoke:ui": "node scripts/smoke-ui.mjs",
    "verify:daemon-defaults": "node scripts/verify-daemon-defaults.mjs",
    "verify:minecraft-meta": "node scripts/verify-minecraft-meta.mjs",
    "lint": "eslint"
  },
  "dependencies": {
    "adm-zip": "^0.5.17",
    "lucide-react": "^1.18.0",
    "next": "16.2.7",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hot-toast": "^2.6.0"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.8",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.7",
    "typescript": "^5"
  }
}
